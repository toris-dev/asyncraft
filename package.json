{
  "name": "asyncraft",
  "version": "0.1.1",
  "description": "Zero-dependency async utilities: retry with backoff, timeout, concurrency limit, and async pool — fully typed, AbortSignal-aware.",
  "keywords": [
    "async",
    "retry",
    "backoff",
    "timeout",
    "concurrency",
    "p-limit",
    "p-retry",
    "p-timeout",
    "promise",
    "abort",
    "typescript"
  ],
  "license": "MIT",
  "author": "toris <ironjustlikethat@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/toris-dev/asyncraft.git"
  },
  "bugs": {
    "url": "https://github.com/toris-dev/asyncraft/issues"
  },
  "homepage": "https://github.com/toris-dev/asyncraft#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "tdd": "vitest --coverage",
    "prepublishOnly": "npm run typecheck && npm run lint && npm run test && npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.0",
    "fast-check": "^4.8.0",
    "prettier": "^3.4.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.20.0",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
